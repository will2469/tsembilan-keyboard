<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tsembilan Keyboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Keyboard 12 tombol sederhana untuk mengetik."
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A000000"
        android:padding="16dp"
        android:layout_marginBottom="32dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Privacy points:"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Tidak memakai internet\n• Tidak menyimpan ketikan\n• Tidak mengirim data\n• Tidak memakai analytics"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_enable_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aktifkan Keyboard"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_select_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilih Keyboard" />

</LinearLayout>
