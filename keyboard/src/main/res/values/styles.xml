<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="KbRowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/kb_main_key_height</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_marginBottom">@dimen/kb_key_gap</item>
    </style>
    
    <style name="KbTopRowStyle" parent="KbRowStyle">
        <item name="android:layout_height">@dimen/kb_top_bar_height</item>
    </style>

    <style name="KbKeyContainerStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">@dimen/kb_key_gap</item>
        <item name="android:background">@drawable/key_background</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
    
    <style name="KbKeyContainerStyle.Last">
        <item name="android:layout_marginEnd">0dp</item>
    </style>

    <style name="KbKeyContainerStyle.Action">
        <item name="android:background">@drawable/key_background_delete</item>
    </style>
    
    <style name="KbKeyContainerStyle.Send">
        <item name="android:background">@drawable/key_background_send</item>
    </style>
    
    <style name="KbKeyTextMainStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/key_text_main</item>
        <item name="android:textSize">@dimen/kb_text_main_number</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="KbKeyTextLettersStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/key_text_secondary</item>
        <item name="android:textSize">@dimen/kb_text_main_letters</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="KbKeyTextActionStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/key_delete_text</item>
        <item name="android:textSize">@dimen/kb_text_action</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KbKeyTextSpecialStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/key_special_text</item>
        <item name="android:textSize">@dimen/kb_text_action</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KbKeyTextSendStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/key_send_text</item>
        <item name="android:textSize">@dimen/kb_text_action</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
