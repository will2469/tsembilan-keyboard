<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/KbTopRowStyle">
    
    <LinearLayout
        android:id="@+id/key_abc"
        style="@style/KbKeyContainerStyle">
        <TextView
            style="@style/KbKeyTextActionStyle"
            android:text="abc" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/key_left"
        style="@style/KbKeyContainerStyle">
        <TextView
            style="@style/KbKeyTextActionStyle"
            android:text="←" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/key_delete"
        style="@style/KbKeyContainerStyle.Action"
        android:layout_marginEnd="0dp">
        <TextView
            style="@style/KbKeyTextActionStyle"
            android:text="HAPUS" />
    </LinearLayout>
</LinearLayout>
